  "bb:datapackage_conformance": {
    "issues": [],
    "conforms": true
  },
  "bb:web_validation": {
    "confidence": "HIGH",
    "checked": "2026-07-04",
    "findings": [
      "FDA publishes FAERS quarterly ASCII extracts as exactly 7 standard tables linked by primaryid: DEMO, DRUG, REAC, OUTC, RPSR, THER, INDI. All 7 are now present in brick/ (THER was missing from the prior build and was rebuilt from raw/ this run).",
      "Coverage is 81 contiguous quarters from 2004Q1 through 2024Q1, matching FDA's stated FAERS start of January 2004. Each of the 7 tables has 81 parquet files (567 total).",
      "Scale is consistent with FDA: DEMO=11,394,813 report rows for 2004-2024 vs FDA dashboard citing ~10M cumulative reports by 2012 (which includes pre-2004 AERS). Total across all 7 relational tables = 266,606,571 rows.",
      "THER schema (primaryid, caseid, dsg_drug_seq, start_dt, end_dt, dur, dur_cod) matches FDA's published THER layout; 31,404,471 rows, no empty files.",
      "Only WARNs are benign: 48 legacy DEMO files (2004-2015) carry an all-null DEATH_DT column, a known artifact of the legacy AERS demo layout, not a build defect.",
      "Snapshot boundary: brick ends at 2024Q1; as of the check date FDA publishes additional later quarters. Coverage from inception to 2024Q1 is complete and contiguous."
    ],
    "source_urls": [
      "https://fis.fda.gov/extensions/FPD-QDE-FAERS/FPD-QDE-FAERS.html",
      "https://www.fda.gov/drugs/fdas-adverse-event-reporting-system-faers/faers-quarterly-data-files-documentation",
      "https://www.fda.gov/drugs/fdas-adverse-event-reporting-system-faers/fda-adverse-event-reporting-system-faers-public-dashboard"
    ]
  }
